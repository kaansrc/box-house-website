# The Box House Hotel — inquiry form (Resend).
# Copy to .env for local dev, or add these as Replit Secrets in production.

# From resend.com (same account as vesper.events). Without it, submissions are
# logged to the server console instead of emailed — handy for testing the form.
RESEND_API_KEY=

# Where leads are delivered. Events forms -> events; contact form routes the
# "Accommodations & Reservations" topic -> reservations, all other topics -> general.
INQUIRY_TO_EVENTS=hostyourevent@theboxhousehotel.com
INQUIRY_TO_GENERAL=info@theboxhousehotel.com
INQUIRY_TO_RESERVATIONS=reservations@theboxhousehotel.com

# A Resend-verified sender. Verify theboxhousehotel.com in the Resend dashboard,
# then use an address on that domain. Until it's verified, Resend only allows the
# test sender below (onboarding@resend.dev), which is the code default.
INQUIRY_FROM=The Box House Hotel <onboarding@resend.dev>
